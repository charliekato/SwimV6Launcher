<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
  xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Fragment>
    <ComponentGroup Id="Components" Directory="INSTALLFOLDER">
      <Component>
        <File Source="..\bin\Release\net8.0-windows\win-x64\publish\SwimV6Launcher.exe" KeyPath="yes" />
      </Component>
      <Component Id="DesktopShorcut">
        <Shortcut Id="DesktopShortcut"
                Name="SwimV6Launcher"
                Description="Launch SwimV6"
                Target="[INSTALLFOLDER]SwimV6Launcher.exe"
                Directory="DesktopFolder"
                WorkingDirectory="INSTALLFOLDER" />
        <RemoveFile Id="RemoveDesktopShortcut" Name="SwimV6Launher.lnk" On="uninstall" 
               Directory="DesktopFolder" />
        <RegistryValue Root="HKCU" Key="Software\OSK\SwimV6Launcher"
               Name="installed" Type="integer" Value="1" />
        </Component>
      <Component Id="ProgramMenuShortcut"
		Directory="ApplicationProgramsFolder">
        <Shortcut Id="ProgramMenuShortcut"
		  Name="SwimV6Launcher"
		  Description="Launch SwimV6"
		  Target="[INSTALLFOLDER]SwimV6Launcher.exe"
		  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveProgramMenuFolder"  
		      On="uninstall" 
		      Directory="ApplicationProgramsFolder" />
		      <!--HKCU = per user  HKLM = per machine -->
        <RegistryKey Root="HKCU" Key="Software\OSK\SwimV6Launcher" >
			    <RegistryValue Name="menu" Type="integer" Value="1" KeyPath="yes"/>
        </RegistryKey>
      </Component>

    </ComponentGroup>
  </Fragment>
</Wix>
